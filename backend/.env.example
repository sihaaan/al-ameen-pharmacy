# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES - Example/Template File
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!
# ==============================================================================

# Database Configuration
# Safe local default. This creates backend/db.sqlite3 and will not touch Neon.
DATABASE_URL=sqlite:///db.sqlite3

# Alternative local PostgreSQL example:
# DATABASE_URL=postgresql://pharmacy_dev:password@localhost:5432/pharmacy_dev

# Optional cloud development:
# Use a separate Neon development branch/database only, never the Railway
# production Neon DATABASE_URL. If you intentionally use a Neon dev branch with
# DEBUG=True, also set ALLOW_DEBUG_NEON_DATABASE=1.
# DATABASE_URL=postgresql://username:password@dev-neon-host.neon.tech/database_name?sslmode=require
# ALLOW_DEBUG_NEON_DATABASE=1
# Persistent PostgreSQL connections are health-checked before reuse. These
# defaults protect Railway/Neon requests from stale SSL connections.
# DATABASE_CONN_MAX_AGE_SECONDS=60
# DATABASE_CONN_HEALTH_CHECKS=1

# Django Security
DJANGO_SECRET_KEY=your-generated-secret-key-here-DO-NOT-USE-THIS-EXAMPLE
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email Configuration
# For development (saves emails to files):
EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend

# For production (sends actual emails via SMTP):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password-here
# DEFAULT_FROM_EMAIL=AL AMEEN PHARMACY <noreply@alameenpharmacy.com>
# ORDER_NOTIFICATION_EMAILS=orders@alameenpharmacy.com,manager@alameenpharmacy.com

# Optional read-only Gmail OAuth for quotation contract/LPO discovery.
# Register this exact callback URL in the Google Cloud OAuth client.
# GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/quotations/gmail/oauth/callback/

# Quotation PDFs can embed uploaded branding/product images from trusted hosts.
# Keep arbitrary remote image fetching disabled unless you really need it.
QUOTATION_PDF_ALLOWED_REMOTE_IMAGE_HOSTS=res.cloudinary.com
# QUOTATION_PDF_ALLOW_REMOTE_IMAGES=0

# Cloudinary Configuration (Cloud Image Storage - FREE tier available)
# Sign up at https://cloudinary.com and copy your CLOUDINARY_URL
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Stripe Payment (Optional - only if using Stripe)
# STRIPE_SECRET_KEY=sk_test_your_test_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# CORS Settings (Production)
# Comma-separated list of allowed frontend URLs
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Production Settings (only set these in production)
# DEBUG=0
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com
# PRODUCTION_DATABASE_HOSTS=your-production-neon-host.neon.tech
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1

# Quotation AI-assisted import parsing (optional)
# API keys stay in environment variables. Staff enable/disable AI parsing from
# Admin Dashboard -> Quotations -> Settings. Leave keys blank to keep AI
# unavailable.
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
QUOTATION_AI_PARSE_GLOBAL_ENABLED=1
QUOTATION_AI_PARSE_PROVIDER=openai
QUOTATION_AI_PARSE_TEXT_MODEL=gpt-4.1-mini
QUOTATION_AI_PARSE_VISION_MODEL=gpt-4.1-mini
QUOTATION_AI_PARSE_MAX_TEXT_CHARS=20000
QUOTATION_AI_PARSE_MAX_PDF_PAGES=10
QUOTATION_AI_PARSE_MAX_RENDERED_PAGES=3
QUOTATION_AI_PARSE_IMAGE_MAX_DIMENSION=1400
QUOTATION_AI_PARSE_TIMEOUT_SECONDS=60
# Separate privacy opt-in for bounded Gmail PDF page images. Requests to the
# configured vision provider use store=false and remain review-only.
QUOTATION_MAILBOX_AI_VISION_ENABLED=0
